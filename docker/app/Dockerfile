FROM python:3.12-slim-bookworm@sha256:d50fb7611f86d04a3b0471b46d7557818d88983fc3136726336b2a4c657aa30b

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /opt/domain-abuse-toolkit

COPY pyproject.toml README.md ./
COPY src ./src

RUN python -m pip install . \
    && groupadd --gid 10001 toolkit \
    && useradd --uid 10001 --gid 10001 --no-create-home --shell /usr/sbin/nologin toolkit \
    && mkdir -p /data \
    && chown toolkit:toolkit /data

USER 10001:10001

EXPOSE 8080

CMD ["python", "-m", "uvicorn", "domain_abuse_toolkit.main:app", "--host", "0.0.0.0", "--port", "8080", "--no-access-log"]
